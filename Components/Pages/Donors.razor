@page "/donors"
@using BloodConnect.Models
@using BloodConnect.Services
@inject BloodBankService BloodBank
@rendermode InteractiveServer

<PageTitle>All Donors</PageTitle>

<h1>Registered Donors</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Blood Group</th>
            <th>Area</th>
            <th>Eligible?</th>
            <th>Available?</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in BloodBank.GetAllDonors())
        {
            <tr>
                <td>@d.Name</td>
                <td><span class="badge bg-danger">@d.BloodGroup.ToLabel()</span></td>
                <td>@d.CityArea</td>
                <td>@(d.IsEligible ? "✅ Yes" : "⏳ Not yet (90-day rule)")</td>
                <td>@(d.IsAvailable ? "✅" : "❌")</td>
            </tr>
        }
    </tbody>
</table>
